# Copy to .env and edit. All values are optional (compose has sane defaults),
# but you should at least set a real MB_API_KEY.

# Shared secret Lidarr sends to BOTH the indexer and the download client.
# Generate one with:  openssl rand -hex 16
MB_API_KEY=changeme

# Run the container as this uid:gid. Match your Lidarr (LinuxServer PUID/PGID,
# usually 1000) so imported files have the right ownership.
PUID=1000
PGID=1000

# Host port to expose the service on.
MB_PORT=8787

# Audio: "native" (best fidelity Opus/m4a, no re-encode) or "mp3".
MB_AUDIO_FORMAT=native
MB_MP3_BITRATE=320

# Quality string put in release titles; must be accepted by your Lidarr
# quality profile (e.g. MP3-320, MP3-256).
MB_QUALITY_TOKEN=MP3-256

# SABnzbd category — must match the category set on the download client in Lidarr.
MB_CATEGORY=music

# Host path mounted to /downloads in the container. See docker-compose.yml for
# the recommended "same path as Lidarr" setup that avoids Remote Path Mapping.
MB_DOWNLOADS_HOST=./downloads
# Completed/incomplete dirs INSIDE the container (under the mount above).
MB_COMPLETED_DIR=/downloads/completed
MB_INCOMPLETE_DIR=/downloads/incomplete

# Optional cookies.txt for YouTube bot-checks (mount it in docker-compose.yml).
# MB_YTDLP_COOKIES=/cookies.txt
